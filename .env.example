# Environment Variables for Libra
# Copy this file to .env and fill in the values

# Together AI API key (required)
TOGETHER_API_KEY=your_together_api_key_here

# CORS origin for the frontend (default: http://localhost:5173)
# For Docker: set to http://localhost (nginx port 80)
# CORS_ORIGIN=http://localhost:5173

# Neo4j connection (Docker defaults; change for custom deployments)
# NEO4J_URI=neo4j://127.0.0.1:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=graphrag

# Flask server
# FLASK_HOST=0.0.0.0
# PORT=5000
# FLASK_DEBUG=false

# Logging
# LOG_LEVEL=INFO

# Frontend API URL (set during Docker build via VITE_API_URL build arg)
# For Docker with nginx proxy, leave empty (uses relative URLs)
# For local dev, defaults to http://localhost:5000
